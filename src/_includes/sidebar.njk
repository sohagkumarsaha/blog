<aside class="sidebar" aria-label="Sidebar">
  <section class="profile-card">
    <img src="{{ site.avatar | url }}" alt="{{ site.author }} avatar" class="profile-avatar">
    <h2>{{ site.author }}</h2>
    <p>{{ site.bio }}</p>
  </section>

  <section class="sidebar-card">
    <h2>Menu</h2>
    <nav class="sidebar-menu" aria-label="Secondary navigation">
      <a href="{{ '/' | url }}">Home</a>
      <a href="{{ '/#blog' | url }}">Blog</a>
      <a href="{{ '/pages/academic-profile/' | url }}">Academic Profile</a>
      <a href="{{ '/pages/publications/' | url }}">Publications</a>
      <a href="{{ '/pages/research-projects/' | url }}">Research Projects</a>
      <a href="{{ '/pages/teaching/' | url }}">Teaching</a>
      <a href="{{ '/pages/cv/' | url }}">CV</a>
    </nav>
  </section>

  <section class="sidebar-card">
    <h2>Most popular <span>(for you)</span></h2>
    <ol id="popular-posts" class="sidebar-list">
      <li class="muted">Read a few posts to build your personal list.</li>
    </ol>
  </section>

  <section class="sidebar-card">
    <h2>You might also like</h2>
    <ol id="recommended-posts" class="sidebar-list">
      <li class="muted">Recommendations appear after you read posts.</li>
    </ol>
  </section>
</aside>
